'use client';

import { useState, useEffect } from 'react';
import { ConnectButton } from '@rainbow-me/rainbowkit';
import { 
  Zap, 
  TrendingUp, 
  TrendingDown, 
  Search, 
  BarChart3, 
  ShieldCheck,
  BrainCircuit,
  MessageSquareQuote,
  ArrowRightLeft,
  AlertTriangle,
  Wallet
} from 'lucide-react';

import { useAccount, useBalance, useSignTypedData, useChainId, useSwitchChain } from 'wagmi';
import { SODEX_ROUTER_ADDRESS, SODEX_ROUTER_ABI } from './constants';
import { valueChain } from './providers';
import { keccak256, stringToBytes, parseSignature } from 'viem';
import { privateKeyToAccount } from 'viem/accounts';

export default function Dashboard() {
  const { address, isConnected } = useAccount();
  const { data: balance } = useBalance({ address });
  const chainId = useChainId();
  const { switchChain } = useSwitchChain();
  
  const { signTypedDataAsync, data: signature, isPending: isSigning, isSuccess: isSigned } = useSignTypedData();
  
  // Custom states for transaction tracking
  const [isExecuting, setIsExecuting] = useState(false);
  const [isConfirmed, setIsConfirmed] = useState(false);
  const [hash, setHash] = useState<string | null>(null);
  
  // Account Status
  const [isRegistered, setIsRegistered] = useState<boolean | null>(null);
  const [accountInfo, setAccountInfo] = useState<any>(null);
  const [autoTrading, setAutoTrading] = useState(false);
  const [isToggling, setIsToggling] = useState(false);
  const [stats, setStats] = useState<any>(null);
  const [symbol, setSymbol] = useState('BTC-USD');
  const [loading, setLoading] = useState(false);
  const [analysis, setAnalysis] = useState<any>(null);
  const [activePayload, setActivePayload] = useState<any>(null);
  const [userPrivateKey, setUserPrivateKey] = useState<string>('');
  const [showPK, setShowPK] = useState(false);

  // Modal & Trade States
  const [showModal, setShowModal] = useState(false);
  const [execLeverage, setExecLeverage] = useState(10);
  const [marginUSD, setMarginUSD] = useState("10");
  const [execTP, setExecTP] = useState("");
  const [execSL, setExecSL] = useState("");
  const [execPrice, setExecPrice] = useState("");
  const [execOrderType, setExecOrderType] = useState(2); // 2 = MARKET, 1 = LIMIT
  const [activeNonce, setActiveNonce] = useState<number>(0);
  const [overrideSide, setOverrideSide] = useState<'LONG' | 'SHORT' | null>(null);

  // Check registration on address change or connection
  useEffect(() => {
    if (isConnected && address) {
      checkRegistration();
      fetchSettings();
      const interval = setInterval(fetchStats, 5000);
      return () => clearInterval(interval);
    } else {
      setIsRegistered(null);
    }
  }, [isConnected, address]);

  const getBaseUrl = () => {
    if (typeof window !== 'undefined') {
      return `http://${window.location.hostname}:8000`;
    }
    return 'http://localhost:8000';
  };

  const fetchSettings = async () => {
    try {
      const resp = await fetch(`${getBaseUrl()}/api/settings`);
      const data = await resp.json();
      setAutoTrading(data.is_active === 1);
    } catch (err) { console.error(err); }
  };

  const fetchStats = async () => {
    try {
      const url = address 
        ? `${getBaseUrl()}/api/stats?address=${address}` 
        : `${getBaseUrl()}/api/stats`;
      const resp = await fetch(url);
      const data = await resp.json();
      setStats(data);
    } catch (err) { console.error(err); }
  };

  const toggleAutoTrading = async () => {
    if (isToggling) return;
    setIsToggling(true);
    const newState = !autoTrading;
    try {
      await fetch(`${getBaseUrl()}/api/settings/toggle?active=${newState}`, { method: 'POST' });
      setAutoTrading(newState);
    } catch (err) { 
      console.error(err); 
    } finally {
      setIsToggling(false);
    }
  };

  const formatSodexSignature = (sig: string) => {
    if (!sig) return "";
    try {
      // Use viem's parseSignature for reliable R, S, V extraction
      const { r, s, v } = parseSignature(sig as `0x${string}`);
      
      // Normalize V: SoDEX expects 00 or 01 (instead of 27 or 28)
      const vNormalized = Number(v) >= 27 ? Number(v) - 27 : Number(v);
      const vHex = vNormalized.toString(16).padStart(2, '0');
      
      // The 0x01 prefix is often required by SoDEX for EIP-712 signatures
      return `0x01${r.slice(2)}${s.slice(2)}${vHex}`;
    } catch (err) {
      console.error("Signature formatting failed:", err);
      return sig; // Fallback to raw signature
    }
  };

  const checkRegistration = async () => {
    try {
      const resp = await fetch(`${getBaseUrl()}/api/check-account?address=${address}`);
      const data = await resp.json();
      setIsRegistered(data.registered);
      setAccountInfo(data);
    } catch (err) {
      console.error("Account check failed:", err);
    }
  };

  const submitTradeWithSig = async (payload: any, signature: string, nonce: number) => {
    try {
      const resp = await fetch(`${getBaseUrl()}/api/execute`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ payload, signature, nonce })
      });
      const result = await resp.json();
      if (result.code === 0) {
        setIsConfirmed(true);
        setTimeout(() => setIsConfirmed(false), 3000);
      } else {
        alert("Execution Error: " + (result.msg || result.error || "Unknown error"));
      }
    } catch (err) {
      console.error("Submit error:", err);
      alert("Network Error during execution");
    } finally {
      setIsExecuting(false);
    }
  };

  const handleAnalyze = async () => {
    setLoading(true);
    try {
      const resp = await fetch(`${getBaseUrl()}/api/analyze?symbol=${symbol}`);
      const data = await resp.json();
      setAnalysis(data);
    } catch (err) {
      console.error("Analysis failed:", err);
      alert("Failed to connect to AI backend. Ensure api.py is running on port 8000.");
    } finally {
      setLoading(false);
    }
  };

  const handleExecute = (manualSide?: 'LONG' | 'SHORT') => {
    if (!analysis) return;
    
    const side = manualSide || (analysis.analysis.decision as 'LONG' | 'SHORT');
    if (side !== 'LONG' && side !== 'SHORT') {
      alert("Please select a side (LONG/SHORT) or wait for AI signal.");
      return;
    }

    setOverrideSide(side);
    setExecLeverage(analysis.analysis.params?.leverage || 10);
    setExecTP(analysis.analysis.params?.tp_price || "");
    setExecPrice(analysis.current_price.toString());
    setExecOrderType(2); // Default to Market for convenience
    
    setShowModal(true);
  };

  const confirmExecute = async (side: 'LONG' | 'SHORT') => {
    if (!analysis || !accountInfo) return;
    
    setIsExecuting(true);
    setShowModal(false); // Close modal
    
    try {
      console.log(`>>> INITIATING UNIFIED TRADE: ${side} x${execLeverage}`);
      
      // Auto-calculate quantity if needed
      const notional = parseFloat(marginUSD) * execLeverage;
      let calcQty = (notional / parseFloat(analysis.current_price)).toFixed(3);
      if (parseFloat(calcQty) <= 0) calcQty = "0.001";

      const payload = {
        account_id: Number(accountInfo.account_id),
        symbol: symbol,
        side: side === 'LONG' ? 1 : 2,
        order_type: 2, // MARKET
        quantity: calcQty,
        price: analysis.current_price.toString(),
        leverage: Math.round(execLeverage),
        margin_mode: 2 // CROSS
      };

      const resp = await fetch(`${getBaseUrl()}/api/trade-unified`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await resp.json();
      console.log("Unified Trade Result:", result);

      if (result.code === 0) {
        alert(`Successfully executed ${side} order!`);
        setOverrideSide(null); // Reset override
        fetchStats(); // Refresh stats
      } else {
        alert(`Execution Error: ${result.error || result.msg || "Unknown error"}`);
      }
    } catch (err) {
      console.error("Unified Trade Failed:", err);
      alert("Unified Trade Failed: Network Error");
    } finally {
      setIsExecuting(false);
    }
  };
        if (isParent) base.price = String(o.price);
        base.quantity = String(o.quantity);
        if (includeStop) {
          base.stopPrice = String(o.stopPrice);
          base.stopType = Number(o.stopType);
          base.triggerType = Number(2);
        }
        base.reduceOnly = Boolean(o.reduceOnly);
        base.positionSide = Number(1);
        return base;
      };

      const finalOrders = [];
      const parentClOrdID = `${accountInfo.account_id}-${nonce}`;
      
      const parentObj = buildOrder({
        clOrdID: parentClOrdID,
        modifier: useBracket ? 3 : 1, 
        side: side, type: execOrderType, price: execPrice.toString(),
        quantity: calcQty, reduceOnly: false
      }, true, false);
      finalOrders.push(parentObj);

      if (useBracket) {
        finalOrders.push(buildOrder({
          clOrdID: `${parentClOrdID}-tp`,
          modifier: 4, side: oppositeSide, type: 2, quantity: calcQty,
          stopPrice: tpVal.toString(), stopType: 2, reduceOnly: true
        }, false, true));
        finalOrders.push(buildOrder({
          clOrdID: `${parentClOrdID}-sl`,
          modifier: 4, side: oppositeSide, type: 2, quantity: calcQty,
          stopPrice: slVal.toString(), stopType: 1, reduceOnly: true
        }, false, true));
      }

      // 1. Build Orders Array manually to control exact JSON string
      const orderStrings = finalOrders.map(o => {
        // STRICT RULE: Market Order (type 2) and Attached Stop (modifier 4) MUST use IOC (3)
        const tif = (Number(o.type) === 2 || Number(o.modifier) === 4) ? 3 : 1;
        const isMarket = Number(o.type) === 2;
        
        const fields = [
          `"clOrdID":"${o.clOrdID}"`,
          `"modifier":${o.modifier}`,
          `"side":${o.side}`,
          `"type":${o.type}`,
          `"timeInForce":${tif}`,
          // For pure market orders, documentation suggests price is optional/slippage only. 
          // Removing it for market orders to ensure "Pure Market" execution.
          (o.price && !isMarket) ? `"price":"${o.price}"` : null,
          `"quantity":"${o.quantity}"`,
          o.stopPrice ? `"stopPrice":"${o.stopPrice}"` : null,
          o.stopType ? `"stopType":${o.stopType}` : null,
          o.stopType ? `"triggerType":2` : null,
          `"reduceOnly":${o.reduceOnly}`,
          `"positionSide":1`
        ].filter(Boolean);
        return `{${fields.join(',')}}`;
      });
 
      const paramsJson = `{"accountID":${Number(accountInfo.account_id)},"symbolID":${symbol === 'BTC-USD' ? 1 : 2},"orders":[${orderStrings.join(',')}]}`;
      const payloadJson = `{"type":"newOrder","params":${paramsJson}}`;
      
      console.log("DEBUG: Sending Order Payload ->", payloadJson);
      
      // Use this exact string for hashing
      const payloadHash = keccak256(stringToBytes(payloadJson));

      // Build Final Payload for the API call
      const payload = {
        type: "newOrder",
        params: JSON.parse(paramsJson)
      };

      setActivePayload(payload);
      
      // 2. Sign EIP-712
      const domain = {
        name: 'futures',
        version: '1',
        chainId: BigInt(138565), // Force ValueChain Testnet ID
        verifyingContract: '0x0000000000000000000000000000000000000000' as `0x${string}`,
      };

      const types = {
        ExchangeAction: [
          { name: 'payloadHash', type: 'bytes32' },
          { name: 'nonce', type: 'uint64' },
        ],
      };

      const message = {
        payloadHash: payloadHash as `0x${string}`,
        nonce: BigInt(nonce),
      };

      if (userPrivateKey && userPrivateKey.length >= 64) {
        // Option A: Private Key Signing (EIP-712)
        const pk = userPrivateKey.startsWith('0x') ? userPrivateKey : `0x${userPrivateKey}`;
        const account = privateKeyToAccount(pk as `0x${string}`);
        const sig = await account.signTypedData({ domain, types, primaryType: 'ExchangeAction', message });
        const finalSig = formatSodexSignature(sig);
        
        setHash(finalSig);
        submitTradeWithSig(payload, finalSig, nonce);
      } else {
        // Option B: Browser Wallet Signature (EIP-712)
        const sig = await signTypedDataAsync({ domain, types, primaryType: 'ExchangeAction', message });
        const finalSig = formatSodexSignature(sig);
        
        setHash(finalSig);
        submitTradeWithSig(payload, finalSig, nonce);
      }
    } catch (err) {
      console.error("Execution failed:", err);
      setIsExecuting(false);
    }
  };

  // Handle successful signature
  useEffect(() => {
    if (isSigned && signature) {
      const sodexSig = formatSodexSignature(signature);
      setHash(sodexSig);
      submitTradeWithSig(activePayload, sodexSig, activeNonce);
    }
  }, [isSigned, signature]);

  const submitTrade = async () => {
    if (!activePayload || !signature) return;
    const sodexSig = formatSodexSignature(signature);
    submitTradeWithSig(activePayload, sodexSig, activeNonce);
  };

  return (
    <main className="flex-1 p-6 md:p-10 max-w-7xl mx-auto w-full">
      {/* Header with Wallet */}
      <header className="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
        <div>
          <h1 className="text-5xl font-black tracking-tighter mb-2 flex items-center gap-3 italic">
            <Zap className="w-12 h-12 fill-accent text-black" />
            SODEX <span className="text-accent underline decoration-8 decoration-black">AI</span>
          </h1>
          <p className="text-slate-400 font-medium">Non-Custodial Intelligence for ValueChain</p>
        </div>
        <div className="neobrutal-card p-4 flex items-center gap-4 bg-slate-900/50">
          <ConnectButton />
        </div>
      </header>

      {/* Active Positions Table (ALWAYS VISIBLE) */}
      {stats?.positions && (
        <div className="neobrutal-card bg-slate-900 overflow-hidden border-slate-700 mb-8">
          <div className="bg-slate-800 p-4 border-b-2 border-slate-700 flex justify-between items-center">
            <span className="text-slate-300 font-black italic tracking-widest uppercase text-sm flex items-center gap-2">
              <TrendingUp className="w-4 h-4 text-accent" /> ACTIVE POSITIONS
            </span>
            <span className="text-xs font-bold text-slate-500 uppercase">
              {stats.positions.length > 0 ? `${stats.positions.length} Live Trades` : 'Portfolio Clear'}
            </span>
          </div>
          
          <div className="overflow-x-auto">
            <table className="w-full text-left border-collapse">
              <thead>
                <tr className="bg-black/50 border-b border-slate-800">
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase">Asset</th>
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase">Side</th>
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase">Size / Lev</th>
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase">Entry Price</th>
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase">Mark Price</th>
                  <th className="p-4 text-[10px] font-black text-slate-500 uppercase text-right">Unrealized PnL</th>
                </tr>
              </thead>
              <tbody>
                {stats.positions.length > 0 ? (
                  stats.positions.map((pos: any, idx: number) => (
                    <tr key={idx} className="border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors">
                      <td className="p-4">
                        <span className="font-black italic text-white">{pos.symbol}</span>
                      </td>
                      <td className="p-4">
                        <span className={`text-[10px] font-black px-2 py-1 ${
                          pos.side === 'LONG' ? 'bg-success/20 text-success' : 'bg-danger/20 text-danger'
                        }`}>
                          {pos.side}
                        </span>
                      </td>
                      <td className="p-4">
                        <div className="flex flex-col">
                          <span className="font-bold text-sm text-white">{pos.size}</span>
                          <span className="text-[10px] text-slate-500 font-bold">x{pos.leverage}</span>
                        </div>
                      </td>
                      <td className="p-4">
                        <span className="font-mono text-xs text-slate-400">
                          ${parseFloat(pos.entry_price).toLocaleString()}
                        </span>
                      </td>
                      <td className="p-4">
                        <span className="font-mono text-xs text-slate-300">
                          ${parseFloat(pos.mark_price).toLocaleString()}
                        </span>
                      </td>
                      <td className="p-4 text-right">
                        <div className={`font-black italic ${
                          parseFloat(pos.unrealized_pnl) >= 0 ? 'text-success' : 'text-danger'
                        }`}>
                          {parseFloat(pos.unrealized_pnl) >= 0 ? '+' : ''}
                          {parseFloat(pos.unrealized_pnl).toFixed(2)} <span className="text-[10px] not-italic">vUSDC</span>
                        </div>
                      </td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colSpan={6} className="p-12 text-center">
                      <div className="flex flex-col items-center justify-center opacity-30">
                        <ArrowRightLeft className="w-12 h-12 mb-3 text-slate-600" />
                        <p className="text-slate-500 font-black italic tracking-widest uppercase text-sm">NO ACTIVE POSITIONS FOUND</p>
                      </div>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        {/* Left Column: Asset Selection & Controls */}
        <div className="lg:col-span-4 space-y-8">
          <section className="neobrutal-card p-6 bg-slate-900">
            <h2 className="text-xl font-bold mb-6 flex items-center gap-2">
              <Search className="w-5 h-5 text-accent" /> ASSET SELECTION
            </h2>
            
            <div className="space-y-4">
              <div className="flex items-center justify-between p-4 bg-black border-2 border-slate-800">
                <div className="flex items-center gap-3">
                  <BrainCircuit className={`w-5 h-5 ${autoTrading ? 'text-accent animate-pulse' : 'text-slate-600'}`} />
                  <div>
                    <span className="block text-xs font-black text-white leading-none">AUTO-TRADING</span>
                    <span className={`text-[10px] font-bold uppercase ${isToggling ? 'text-accent animate-pulse' : 'text-slate-500'}`}>
                      {isToggling ? 'Processing...' : autoTrading ? 'Autonomous Active' : 'Manual Mode'}
                    </span>
                  </div>
                </div>
                <button 
                  onClick={toggleAutoTrading}
                  disabled={isToggling}
                  className={`w-12 h-6 rounded-none border-2 flex items-center transition-all ${isToggling ? 'opacity-50 cursor-wait' : ''} ${autoTrading ? 'border-accent bg-accent/20 justify-end' : 'border-slate-700 bg-slate-800 justify-start'}`}
                >
                  <div className={`w-4 h-4 m-0.5 ${isToggling ? 'bg-slate-500 animate-spin' : autoTrading ? 'bg-accent' : 'bg-slate-500'}`}></div>
                </button>
              </div>

              <div>
                <label className="block text-xs font-black mb-2 text-slate-500 uppercase tracking-widest">Select Instrument</label>
                <select 
                  value={symbol}
                  onChange={(e) => setSymbol(e.target.value)}
                  className="w-full p-4 bg-black border-2 border-slate-700 text-white font-bold focus:border-accent outline-none appearance-none"
                >
                  <option value="BTC-USD">BITCOIN (BTC-USD)</option>
                  <option value="ETH-USD">ETHEREUM (ETH-USD)</option>
                  <option value="SOL-USD">SOLANA (SOL-USD)</option>
                </select>
              </div>

              <button 
                onClick={handleAnalyze}
                disabled={loading || autoTrading}
                className={`w-full neobrutal-button p-5 flex items-center justify-center gap-3 disabled:opacity-50 disabled:transform-none ${autoTrading ? 'bg-slate-800 border-slate-700 text-slate-500 cursor-not-allowed' : ''}`}
              >
                {loading ? (
                  <span className="flex items-center gap-2">
                    <BrainCircuit className="animate-spin w-5 h-5" /> 
                    AI THINKING...
                  </span>
                ) : autoTrading ? (
                  <>
                    <ShieldCheck className="w-5 h-5" /> 
                    AUTO-MODE ACTIVE
                  </>
                ) : (
                  <>
                    <Zap className="w-5 h-5" /> 
                    ANALYZE MARKET
                  </>
                )}
              </button>
            </div>
          </section>

          {/* Wallet Status Card */}
          <section className="neobrutal-card p-6 bg-slate-900 border-accent/20">
             <h2 className="text-xl font-bold mb-4 flex items-center gap-2">
              <ShieldCheck className="w-5 h-5 text-accent" /> SECURITY STATUS
            </h2>
            <div className="space-y-3">
              <div className="flex justify-between items-center p-3 bg-black/50 border border-slate-800">
                <span className="text-slate-500 font-bold text-sm">NETWORK</span>
                {isConnected && chainId !== valueChain.id ? (
                  <button 
                    onClick={() => switchChain({ chainId: valueChain.id })}
                    className="text-[10px] font-black bg-danger/20 text-danger px-2 py-1 border border-danger/20 animate-pulse uppercase"
                  >
                    WRONG NETWORK (SWITCH)
                  </button>
                ) : (
                  <span className="text-success font-black text-xs bg-success/10 px-2 py-1 border border-success/20 uppercase">
                    {isConnected ? 'VALUECHAIN OK' : 'DISCONNECTED'}
                  </span>
                )}
              </div>
              <div className="flex justify-between items-center p-3 bg-black/50 border border-slate-800">
                <span className="text-slate-500 font-bold text-sm">SODEX ACCOUNT</span>
                {isConnected ? (
                  isRegistered === null ? (
                    <span className="text-slate-500 text-xs animate-pulse">CHECKING...</span>
                  ) : isRegistered ? (
                    <span className="text-success font-black text-xs bg-success/10 px-2 py-1 border border-success/20 uppercase">
                      ID: {accountInfo?.account_id}
                    </span>
                  ) : (
                    <span className="text-danger font-black text-xs bg-danger/10 px-2 py-1 border border-danger/20 uppercase">
                      NOT REGISTERED
                    </span>
                  )
                ) : (
                  <span className="text-slate-500 text-xs italic uppercase">---</span>
                )}
              </div>
              <div className="flex justify-between items-center p-3 bg-black/50 border border-slate-800">
                <span className="text-slate-500 font-bold text-sm">WALLET BALANCE</span>
                <span className="text-white font-black text-xs italic">
                  {balance ? `${parseFloat(balance.formatted).toFixed(4)} ${balance.symbol}` : '---'}
                </span>
              </div>
              <div className="flex justify-between items-center p-3 bg-success/5 border border-success/20">
                <span className="text-success font-bold text-sm uppercase italic">SODEX BALANCE</span>
                <span className="text-success font-black text-sm italic">
                  {accountInfo?.balance ? `${parseFloat(accountInfo.balance).toLocaleString()} vUSDC` : '0.00 vUSDC'}
                </span>
              </div>
            </div>
          </section>

          {/* Session Private Key Section (Multi-User Support) */}
          <section className="neobrutal-card p-6 bg-slate-900 border-warning/30">
            <h2 className="text-xl font-bold mb-4 flex items-center gap-2">
              <Wallet className="w-5 h-5 text-warning" /> SESSION AUTH
            </h2>
            <div className="space-y-4">
              <div className="bg-warning/10 p-4 border border-warning/30">
                <div className="flex items-start gap-3">
                  <AlertTriangle className="w-5 h-5 text-warning shrink-0" />
                  <p className="text-[10px] text-warning font-bold leading-tight uppercase">
                    MULTI-USER MODE: Enter your Private Key to enable gas-less instant execution. 
                    Your key is stored only in browser memory.
                    <span className="block mt-1 text-white underline italic">RECOMMENDED: USE A BURNER WALLET ONLY!</span>
                  </p>
                </div>
              </div>
              
              <div className="relative">
                <input 
                  type={showPK ? "text" : "password"}
                  placeholder="0x... (Your Private Key)"
                  value={userPrivateKey}
                  onChange={(e) => setUserPrivateKey(e.target.value)}
                  className="w-full bg-black border-2 border-slate-700 p-3 pr-10 text-xs text-white font-mono outline-none focus:border-warning"
                />
                <button 
                  onClick={() => setShowPK(!showPK)}
                  className="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-white"
                >
                  {showPK ? "🙈" : "👁️"}
                </button>
              </div>
              
              {userPrivateKey && (
                <div className="flex items-center gap-2 text-[10px] text-success font-black italic">
                  <ShieldCheck className="w-3 h-3" /> SESSION KEY ACTIVE
                </div>
              )}
            </div>
          </section>
        </div>

        {/* Right Column: AI Analysis & Recommendation */}
        <div className="lg:col-span-8">
          {!analysis && !loading ? (
            <div className="space-y-6 h-full">
              {autoTrading && (
                <div className="neobrutal-card p-8 bg-accent/10 border-accent/30 animate-in fade-in slide-in-from-top-4 duration-500">
                  <div className="flex items-center gap-4 mb-4">
                    <div className="relative">
                      <BrainCircuit className="w-10 h-10 text-accent animate-pulse" />
                      <div className="absolute -top-1 -right-1 w-3 h-3 bg-success rounded-full border-2 border-slate-900 animate-ping"></div>
                    </div>
                    <div>
                      <h3 className="text-xl font-black italic text-white uppercase tracking-tighter">Autonomous Monitor Active</h3>
                      <p className="text-xs font-bold text-accent uppercase tracking-widest">Scanning {symbol} every 30s</p>
                    </div>
                  </div>
                  <div className="bg-black/40 p-6 border-l-4 border-accent italic text-slate-400">
                    <p className="text-sm leading-relaxed">
                      "Bot is currently monitoring global news and technical indicators. 
                      <span className="text-white font-bold ml-1">Status: Waiting for momentum.</span> 
                      The system will automatically execute orders when the AI Signal Score exceeds the threshold."
                    </p>
                  </div>
                  <div className="mt-6 flex gap-4">
                    <div className="flex-1 p-3 bg-slate-900 border border-slate-800 text-[10px] font-black uppercase text-slate-500">
                      Last Check: <span className="text-white ml-2">{new Date().toLocaleTimeString()}</span>
                    </div>
                    <div className="flex-1 p-3 bg-slate-900 border border-slate-800 text-[10px] font-black uppercase text-slate-500">
                      Engine: <span className="text-white ml-2">Hybrid Ensemble (Gemini + Llama)</span>
                    </div>
                  </div>
                </div>
              )}

              <div className="neobrutal-card p-12 flex flex-col items-center justify-center bg-slate-900 border-dashed border-slate-700 opacity-50 flex-1 min-h-[400px]">
                <BarChart3 className="w-16 h-16 text-slate-700 mb-4" />
                <p className="text-slate-500 font-bold uppercase tracking-widest text-center">
                  {autoTrading ? 'Autonomous Engine is Controlling the Market.' : 'Ready for Analysis. Select an asset and trigger the AI engine.'}
                </p>
              </div>
            </div>
          ) : loading ? (
             <div className="neobrutal-card p-12 flex flex-col items-center justify-center bg-slate-900 h-full min-h-[500px]">
              <div className="relative mb-8">
                 <div className="w-24 h-24 border-4 border-accent border-t-transparent rounded-full animate-spin"></div>
                 <BrainCircuit className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 text-accent" />
              </div>
              <h3 className="text-2xl font-black text-white italic mb-2 tracking-tighter">PROCESSING MACRO DATA</h3>
              <p className="text-slate-500 font-bold uppercase tracking-widest text-sm animate-pulse">
                Fetching SoSoValue news & querying MiniMax M2.7...
              </p>
            </div>
          ) : (
            <div className="space-y-6">
              {/* Analysis Result */}
              <div className="neobrutal-card bg-slate-900 overflow-hidden">
                <div className="bg-black p-4 border-b-2 border-slate-800 flex justify-between items-center">
                  <span className="text-accent font-black italic tracking-widest uppercase text-sm">AI SENTIMENT ANALYSIS</span>
                  <div className="flex items-center gap-4">
                    <span className="text-slate-500 text-xs font-bold">RELIABILITY: HIGH</span>
                    <span className="text-xs font-black bg-accent/20 text-accent px-2 py-1">NVIDIA NIM</span>
                  </div>
                </div>

                <div className="p-8">
                  <div className="flex flex-col md:flex-row gap-8 mb-8">
                    <div className={`p-6 rounded-none border-4 ${
                      analysis.analysis.decision === 'LONG' ? 'border-success bg-success/5' : 
                      analysis.analysis.decision === 'SHORT' ? 'border-danger bg-danger/5' : 
                      'border-slate-700 bg-slate-800/50'
                    } flex-1 flex flex-col items-center justify-center text-center`}>
                      <span className="text-xs font-black text-slate-500 uppercase tracking-[0.2em] mb-2">Final Recommendation</span>
                      <h3 className={`text-6xl font-black italic tracking-tighter ${
                        analysis.analysis.decision === 'LONG' ? 'text-success' : 
                        analysis.analysis.decision === 'SHORT' ? 'text-danger' : 
                        'text-slate-400'
                      }`}>
                        {analysis.analysis.decision}
                      </h3>
                    </div>

                    <div className="flex-1 space-y-4">
                       <div className="flex items-center gap-3">
                        <MessageSquareQuote className="w-6 h-6 text-accent" />
                        <h4 className="text-lg font-black italic tracking-tight">AI REASONING</h4>
                      </div>
                      <p className="text-slate-300 font-medium leading-relaxed bg-black/40 p-4 border-l-4 border-accent italic">
                        {analysis.analysis.reasoning?.strategy || analysis.analysis.reasoning || "No reasoning provided."}
                      </p>
                    </div>
                  </div>

                  {/* Execution Plan Card */}
                  <div className="neobrutal-card p-6 bg-black border-slate-700">
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                      <div className="p-4 border border-slate-800">
                        <span className="block text-[10px] font-black text-slate-500 uppercase mb-1">ENTRY PRICE</span>
                        <span className="text-2xl font-black text-white italic tracking-tighter">${parseFloat(analysis.current_price).toLocaleString()}</span>
                      </div>
                      <div className="p-4 border border-slate-800">
                        <span className="block text-[10px] font-black text-slate-500 uppercase mb-1 text-success">TAKE PROFIT</span>
                        <span className="text-2xl font-black text-success italic tracking-tighter">
                          {analysis.analysis.params?.tp_price ? `$${analysis.analysis.params.tp_price}` : '---'}
                        </span>
                      </div>
                      <div className="p-4 border border-slate-800">
                        <span className="block text-[10px] font-black text-slate-500 uppercase mb-1 text-danger">STOP LOSS</span>
                        <span className="text-2xl font-black text-danger italic tracking-tighter">
                           {analysis.analysis.params?.sl_price ? `$${analysis.analysis.params.sl_price}` : '---'}
                        </span>
                      </div>
                    </div>

                  {analysis.analysis.decision === 'HOLD' ? (
                    <div className="mt-8 space-y-4">
                      <div className="flex items-center gap-2 mb-2">
                        <div className="h-[1px] flex-1 bg-slate-800"></div>
                        <span className="text-[10px] font-black text-warning uppercase italic tracking-widest">Manual Override</span>
                        <div className="h-[1px] flex-1 bg-slate-800"></div>
                      </div>
                      <div className="flex gap-4">
                        <button 
                          onClick={() => handleExecute('LONG')}
                          disabled={!isConnected || isRegistered === false}
                          className="flex-1 neobrutal-button bg-success/20 hover:bg-success text-success hover:text-black p-4 font-black italic flex items-center justify-center gap-2 border-success/30 disabled:opacity-30"
                        >
                          <TrendingUp className="w-5 h-5" /> FORCE LONG
                        </button>
                        <button 
                          onClick={() => handleExecute('SHORT')}
                          disabled={!isConnected || isRegistered === false}
                          className="flex-1 neobrutal-button bg-danger/20 hover:bg-danger text-danger hover:text-black p-4 font-black italic flex items-center justify-center gap-2 border-danger/30 disabled:opacity-30"
                        >
                          <TrendingDown className="w-5 h-5" /> FORCE SHORT
                        </button>
                      </div>
                    </div>
                  ) : (
                    <button 
                      className={`w-full mt-8 neobrutal-button p-6 text-xl flex items-center justify-center gap-4 disabled:opacity-50 ${
                        (!isConnected || chainId !== valueChain.id || !isRegistered) ? 'bg-slate-800 cursor-not-allowed text-slate-600' :
                        isConfirmed ? 'bg-success' : 'bg-success hover:bg-success/90'
                      }`}
                      onClick={() => {
                        if (chainId !== valueChain.id) switchChain({ chainId: valueChain.id });
                        else handleExecute();
                      }}
                      disabled={isExecuting || isSigning || !isConnected || (isConnected && isRegistered === false)}
                    >
                      {!isConnected ? (
                        <>
                          <Wallet className="w-6 h-6" />
                          CONNECT WALLET
                        </>
                      ) : chainId !== valueChain.id ? (
                        <>
                          <AlertTriangle className="w-6 h-6 text-danger" />
                          SWITCH TO VALUECHAIN
                        </>
                      ) : isRegistered === false ? (
                        <>
                          <AlertTriangle className="w-6 h-6 text-danger" />
                          NOT REGISTERED ON SODEX
                        </>
                      ) : isExecuting || isSigning ? (
                        <>
                          <BrainCircuit className="animate-spin w-6 h-6" />
                          {isSigning ? 'SIGNING MESSAGE...' : 'EXECUTING...'}
                        </>
                      ) : (
                        <>
                          <Zap className="w-6 h-6 fill-white" />
                          EXECUTE ON-CHAIN
                        </>
                      )}
                    </button>
                  )}

                    {hash && (
                      <div className="mt-4 p-3 bg-slate-800 border border-slate-700 text-xs font-mono break-all">
                        <span className="text-slate-500 font-black mr-2">SIGNATURE:</span>
                        <span className="text-accent">
                          {hash.substring(0, 40)}...
                        </span>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Trade Confirmation Modal */}
      {showModal && analysis && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm">
          <div className="neobrutal-card bg-slate-900 w-full max-w-lg border-4 border-black overflow-hidden animate-in fade-in zoom-in duration-200">
            <div className="bg-accent p-4 border-b-4 border-black flex justify-between items-center">
              <h3 className="text-black font-black italic tracking-tighter text-2xl uppercase">Confirm Order</h3>
              <button onClick={() => setShowModal(false)} className="text-black font-black text-xl hover:scale-125 transition-transform">✕</button>
            </div>
            
            <div className="p-8 space-y-6">
              {/* Order Summary Header */}
              <div className={`p-4 border-2 border-black flex justify-between items-center ${
                analysis.analysis.decision === 'LONG' ? 'bg-success/20 border-success' : 'bg-danger/20 border-danger'
              }`}>
                <div className="flex flex-col">
                  <span className="text-[10px] font-black text-slate-400 uppercase">Target Asset</span>
                  <span className="text-xl font-black italic">{symbol}</span>
                </div>
                <div className="text-right">
                  <span className="text-[10px] font-black text-slate-400 uppercase">Direction</span>
                  <span className={`block text-2xl font-black italic ${
                    analysis.analysis.decision === 'LONG' ? 'text-success' : 'text-danger'
                  }`}>{analysis.analysis.decision}</span>
                </div>
              </div>

              {/* Order Type Selector */}
              <div className="flex gap-2 p-1 bg-black border-2 border-slate-700">
                <button 
                  onClick={() => setExecOrderType(2)}
                  className={`flex-1 p-2 text-[10px] font-black uppercase transition-all ${execOrderType === 2 ? 'bg-accent text-black' : 'text-slate-500 hover:text-white'}`}
                >
                  Market Price
                </button>
                <button 
                  onClick={() => setExecOrderType(1)}
                  className={`flex-1 p-2 text-[10px] font-black uppercase transition-all ${execOrderType === 1 ? 'bg-accent text-black' : 'text-slate-500 hover:text-white'}`}
                >
                  Limit Order
                </button>
              </div>

              {/* Editable Inputs */}
              <div className="grid grid-cols-2 gap-4">
                <div className="space-y-2">
                  <label className="text-xs font-black text-slate-500 uppercase">Margin (vUSDC)</label>
                  <input 
                    type="text" 
                    value={marginUSD} 
                    onChange={(e) => setMarginUSD(e.target.value)}
                    className="w-full bg-black border-2 border-slate-700 p-3 text-white font-black focus:border-accent outline-none"
                  />
                </div>
                <div className="space-y-2">
                  <label className="text-xs font-black text-slate-500 uppercase">Leverage (x)</label>
                  <input 
                    type="number" 
                    value={execLeverage} 
                    onChange={(e) => setExecLeverage(parseInt(e.target.value))}
                    className="w-full bg-black border-2 border-slate-700 p-3 text-white font-black focus:border-accent outline-none"
                  />
                </div>
                
                {execOrderType === 1 && (
                  <div className="col-span-2 space-y-2 animate-in slide-in-from-top-2 duration-200">
                    <label className="text-xs font-black text-warning uppercase italic">Entry Price (Limit)</label>
                    <input 
                      type="text" 
                      value={execPrice} 
                      onChange={(e) => setExecPrice(e.target.value)}
                      className="w-full bg-black border-4 border-warning p-3 text-white font-black focus:border-accent outline-none"
                    />
                  </div>
                )}

                <div className="space-y-2">
                  <label className="text-xs font-black text-slate-500 uppercase text-success">Take Profit ($)</label>
                  <input 
                    type="text" 
                    value={execTP} 
                    onChange={(e) => setExecTP(e.target.value)}
                    placeholder="Auto-suggested"
                    className="w-full bg-black border-2 border-slate-700 p-3 text-success font-black focus:border-success outline-none"
                  />
                </div>
                <div className="space-y-2">
                  <label className="text-xs font-black text-slate-500 uppercase text-danger">Stop Loss ($)</label>
                  <input 
                    type="text" 
                    value={execSL} 
                    onChange={(e) => setExecSL(e.target.value)}
                    placeholder="Auto-suggested"
                    className="w-full bg-black border-2 border-slate-700 p-3 text-danger font-black focus:border-danger outline-none"
                  />
                </div>
              </div>

              {/* Quantity Estimate */}
              <div className="p-4 bg-slate-800 border-2 border-black flex justify-between items-center">
                <div className="flex items-center gap-2">
                  <BarChart3 className="w-4 h-4 text-accent" />
                  <span className="text-xs font-bold text-slate-400 uppercase">Est. Quantity ({symbol.split('-')[0]})</span>
                </div>
                <span className="text-lg font-black text-white italic">
                  {( (parseFloat(marginUSD) * execLeverage) / parseFloat(analysis.current_price) ).toFixed(4)}
                </span>
              </div>

              {/* Action Buttons */}
              <div className="flex gap-4 pt-4">
                <button 
                  onClick={() => setShowModal(false)}
                  className="flex-1 p-4 border-2 border-black bg-slate-700 font-black hover:bg-slate-600 transition-colors uppercase tracking-widest text-xs"
                >
                  Cancel
                </button>
                <button 
                  onClick={confirmExecute}
                  className="flex-2 p-4 border-2 border-black bg-success text-black font-black hover:bg-success/90 transition-colors uppercase tracking-widest text-xs flex items-center justify-center gap-2"
                >
                  <ShieldCheck className="w-4 h-4" />
                  Confirm & Sign
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </main>
  );
}
